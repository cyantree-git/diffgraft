BUG 2 — MEDIUM: Jittery scroll sync

Problem:
requestAnimationFrame releases the sync lock
too early. The programmatic scroll on pane B
triggers another scroll event before the frame
completes, causing micro-feedback loops.

Fix:
Replace requestAnimationFrame with a longer
debounce using setTimeout:
```typescript
let syncTimeout: ReturnType<typeof setTimeout> | null = null

function handleScrollA(e: Event) {
  if (isSyncingRef.current) return
  isSyncingRef.current = true
  
  const el = e.target as HTMLDivElement
  if (scrollRefB.current) {
    scrollRefB.current.scrollTop = el.scrollTop
    scrollRefB.current.scrollLeft = el.scrollLeft
  }
  
  if (syncTimeout) clearTimeout(syncTimeout)
  syncTimeout = setTimeout(() => {
    isSyncingRef.current = false
    syncTimeout = null
  }, 50)
}

// Same pattern for handleScrollB
```

50ms is enough time for the programmatic scroll
to complete and its event to fire and be ignored.
After 50ms the lock releases cleanly.

