Keyboard shortcuts:
Add a useEffect in SideBySideDiffTable.tsx:

useEffect(() => {
  const handler = (e: KeyboardEvent) => {
    if (e.key === 'F7' || (e.altKey && e.key === 'ArrowDown')) {
      e.preventDefault()
      navigateNext()
    }
    if (e.key === 'F7' && e.shiftKey ||
        (e.altKey && e.key === 'ArrowUp')) {
      e.preventDefault()
      navigatePrev()
    }
  }
  window.addEventListener('keydown', handler)
  return () => window.removeEventListener('keydown', handler)
}, [currentChangePos, changeIndex])

F7 = next change (matches IntelliJ exactly)
Shift+F7 = previous change (matches IntelliJ exactly)
Alt+Down / Alt+Up = alternative for non-Mac users

