Step 6: Create diff.rs

Implement these functions:

pub fn diff_schema(
  schema_a: &CsvSchema,
  schema_b: &CsvSchema,
) -> SchemaDiff
  - Compare columns between two schemas
  - Return added, removed, and common columns

pub fn diff_csv(
  rows_a: &[Vec<String>],
  rows_b: &[Vec<String>],
  schema_a: &CsvSchema,
  schema_b: &CsvSchema,
  config: &DiffConfig,
) -> Result<DiffResult, AppError>
  - If config.primary_keys is empty: diff by row order
  - If config.primary_keys is set: diff by primary key
    1. Build HashMap<Vec<String>, usize> keyed by primary key values
    2. Keys in A not in B → deleted_rows
    3. Keys in B not in A → added_rows
    4. Keys in both → compare cell by cell → modified_rows
  - Respect config.ignore_columns
  - Respect config.case_sensitive
  - Return DiffResult

fn build_key_index(
  rows: &[Vec<String>],
  schema: &CsvSchema,
  key_columns: &[String],
) -> Result<HashMap<Vec<String>, usize>, AppError>
  - Private helper
  - Returns error AppError::DuplicateKey if primary key is not unique

