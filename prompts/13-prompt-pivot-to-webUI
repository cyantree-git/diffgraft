## STEP 10: apps/web/src/components/FilePane.tsx

Web version. Receives file content string instead
of file path. Passes content to WASM functions.

import React from 'react'
import { DropZone } from './DropZone'
import { DiffPaneTable } from './DiffPaneTable'
import type {
  CsvReadResult, DiffResult, UnifiedRow
} from '../types/diffgraft'

interface FilePaneProps {
  side: 'A' | 'B'
  file: CsvReadResult | null
  diffResult: DiffResult | null
  unifiedRows: UnifiedRow[]
  currentChangeIndex: number
  changeIndex: number[]
  scrollRef: React.RefObject<HTMLDivElement>
  firstRowRef?: React.RefObject<HTMLTableRowElement | null>
  onFileLoaded: (
    result: CsvReadResult,
    content: string,
    name: string
  ) => void
}

export function FilePane({
  side, file, diffResult, unifiedRows,
  currentChangeIndex, changeIndex,
  scrollRef, firstRowRef, onFileLoaded,
}: FilePaneProps) {
  if (!file || !diffResult) {
    return (
      <DropZone side={side} onFileLoaded={onFileLoaded} />
    )
  }

  return (
    <div ref={scrollRef} className="pane-scroll-container">
      <DiffPaneTable
        side={side}
        schema={file.schema}
        rows={file.rows}
        diffResult={diffResult}
        unifiedRows={unifiedRows}
        currentChangeIndex={currentChangeIndex}
        changeIndex={changeIndex}
        firstRowRef={firstRowRef}
      />
    </div>
  )
}

